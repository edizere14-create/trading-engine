GOPLUS_API_URL=https://api.gopluslabs.io
SECURITY_FAIL_MODE=closed

TELEGRAM_BOT_TOKEN=__SET_AT_DEPLOY_TIME__
TELEGRAM_CHAT_ID=__SET_AT_DEPLOY_TIME__

INITIAL_CAPITAL_USD=1000
MAX_CONCURRENT_POSITIONS=5
MAX_TRADES_PER_DAY=20
MAX_DAILY_LOSS_PCT=20
MAX_WEEKLY_LOSS_PCT=40
