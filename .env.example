# Copy this to .env for local development.
# Never commit real secrets.

REDIS_URL=redis://redis:6379/0

HELIUS_API_KEY=__SET_AT_DEPLOY_TIME__
PRIMARY_RPC=https://mainnet.helius-rpc.com/?api-key=__SET_AT_DEPLOY_TIME__
BACKUP_RPC=https://rpc.shyft.to?api_key=__SET_AT_DEPLOY_TIME__
SAFETY_RPC_URL=https://rpc.shyft.to?api_key=__SET_AT_DEPLOY_TIME__

PAPER_MODE=true
LIVE_TRADING_ARMED=false
AUTONOMOUS_ONLY=true

ARB_RPC_URL=https://arb1.arbitrum.io/rpc
ARB_PRIVATE_KEY=__SET_AT_DEPLOY_TIME__
INTENT_API_KEY=__SET_AT_DEPLOY_TIME__
INTENT_RESOLVER_URL=https://api.1inch.dev/fusion
INTENT_RESOLVER_CONTRACT=0x111111125421caae97131560c0d0c32724817a2d

CAMELOT_SUBGRAPH=https://api.thegraph.com/subgraphs/name/camelotlabs/camelot-amm-v3
